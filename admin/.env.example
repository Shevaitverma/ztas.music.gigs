# ============================================
# ZTS Music — Admin frontend  ·  dev port :3001  (next dev -p 3001)
# ============================================
# Copy to .env.local and fill in. .env.local is gitignored.
# NEXT_PUBLIC_* are PUBLIC (inlined into the bundle).
# Never put service-account JSON or admin SDK keys here.

# --- Backend API ---
NEXT_PUBLIC_API_URL=http://localhost:8080/api/v1

# --- Firebase Web SDK (public per Firebase) ---
# Firebase Console > Project Settings > General > Your apps (Web app).
NEXT_PUBLIC_FIREBASE_PROJECT_ID=zts-music
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=zts-music.firebaseapp.com
# NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=zts-music.appspot.com
