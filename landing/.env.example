# ============================================
# ZTS Music — Landing / marketing site
# ============================================
# Copy to .env.local and fill in. .env.local is gitignored.
# NEXT_PUBLIC_* are PUBLIC (inlined into the bundle).

# Canonical site URL (used for SEO metadata + sitemap). Defaults to prod URL.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Backend API (if the landing site calls it)
NEXT_PUBLIC_API_URL=http://localhost:8080/api/v1

# Google Search Console verification token (optional, prod only)
# GOOGLE_SITE_VERIFICATION=

# --- Firebase Web SDK (public per Firebase) — only if landing uses auth ---
NEXT_PUBLIC_FIREBASE_PROJECT_ID=zts-music
# NEXT_PUBLIC_FIREBASE_API_KEY=
# NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
# NEXT_PUBLIC_FIREBASE_APP_ID=
