# ============================================
# ZTS Music Platform API - Environment Configuration
# ============================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# ============================================
# Application Settings
# ============================================
NODE_ENV=development
PORT=8080

# ============================================
# Database (MongoDB)
# ============================================
# Local development
DATABASE_URL=mongodb://localhost:27017
DATABASE_NAME=music-server

# Production (MongoDB Atlas example)
# DATABASE_URL=mongodb+srv://user:password@cluster.mongodb.net

# ============================================
# Firebase Admin SDK
# ============================================
# Get these from Firebase Console > Project Settings > Service Accounts
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour-Private-Key-Here\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com

# ============================================
# JWT Authentication
# ============================================
# Generate strong secrets: openssl rand -base64 64
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRATION=1h
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this-in-production
JWT_REFRESH_EXPIRATION=7d

# ============================================
# Field-Level Encryption (PII at rest)
# ============================================
# REQUIRED in production. 32 bytes (64 hex chars).
# Generate with: openssl rand -hex 32
# Used to encrypt Aadhaar/PAN/bank account/IFSC at rest.
ENCRYPTION_KEY=

# ============================================
# Rate Limiter / Trusted Proxies
# ============================================
# Comma-separated source IPs that are allowed to set X-Forwarded-For.
# Direct connections from other IPs are rate-limited by their socket IP.
# Default: 127.0.0.1,::1
TRUSTED_PROXIES=127.0.0.1,::1

# ============================================
# CORS Configuration
# ============================================
# Comma-separated list of allowed origins
CORS_ORIGIN=http://localhost:3000,http://localhost:3001,http://localhost:5173

# In production: REQUIRED, comma-separated origin list, MUST NOT contain "*"
# (wildcard + credentials:true is rejected by browsers and unsafe).
#
# Example production:
# CORS_ORIGIN=https://app.zts.music,https://admin.zts.music

# ============================================
# AWS S3 (Optional - for file uploads)
# ============================================
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_S3_BUCKET=your-bucket-name
AWS_PRESIGNED_URL_EXPIRY=3600

# ============================================
# Logging
# ============================================
# Log levels: debug, info, warn, error
LOG_LEVEL=info

# ============================================
# Feature Flags
# ============================================
# Enable activity logging (disabled by default for new platforms)
# Activity logs track user actions for audit purposes
# Set to 'true' when you need audit trails
ENABLE_ACTIVITY_LOGGING=false

# Verbose auth-plugin debug logs (NEVER logs tokens or full payloads).
# Default: false. Set to 'true' only for local debugging.
AUTH_DEBUG_LOGGING=false
