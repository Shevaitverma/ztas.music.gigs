{
  "name": "ai.zts.music.server",
  "version": "1.0.0",
  "description": "ZTS Music Platform API - Bun + Elysia Backend",
  "module": "src/index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "start": "NODE_ENV=production bun src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun --minify --sourcemap",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "clean": "rm -rf dist node_modules/.cache"
  },
  "keywords": ["music", "gig", "marketplace", "bun", "elysia", "api"],
  "author": "ZTS Music Platform",
  "license": "MIT",
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^25.0.2",
    "bun-types": "^1.3.4",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.948.0",
    "@aws-sdk/s3-request-presigner": "^3.948.0",
    "@elysiajs/bearer": "^1.4.0",
    "@elysiajs/cors": "^1.4.0",
    "@elysiajs/jwt": "^1.4.0",
    "@elysiajs/static": "^1.4.0",
    "@elysiajs/swagger": "^1.3.1",
    "elysia": "^1.4.19",
    "firebase-admin": "^13.6.0",
    "mongoose": "^9.0.1"
  }
}
