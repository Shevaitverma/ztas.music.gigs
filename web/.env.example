# ============================================
# ZTS Music — Web (client) frontend  ·  dev port :3000
# ============================================
# Copy to .env.local and fill in. .env.local is gitignored.
# NEXT_PUBLIC_* are inlined into the client bundle at build time and are PUBLIC.
# Never put server secrets here.

# --- Backend API ---
NEXT_PUBLIC_API_URL=http://localhost:8080/api/v1
NEXT_PUBLIC_WS_URL=ws://localhost:8080/ws/bids

# Server-side fetches (SSR/middleware). Optional — falls back to API_URL.
# INTERNAL_API_URL=http://localhost:8080/api/v1

# --- Firebase Web SDK (public per Firebase) ---
# Firebase Console > Project Settings > General > Your apps (Web app).
# authDomain/storageBucket are derived from project ID if omitted.
NEXT_PUBLIC_FIREBASE_PROJECT_ID=zts-music
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=zts-music.firebaseapp.com
# NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=zts-music.appspot.com
